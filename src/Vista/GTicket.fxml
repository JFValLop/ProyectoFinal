<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ControladorFX.GTicketFXController">
   <children>
      
      <Label layoutX="31.0" layoutY="14.0" text="Gestión de Tickets de Entrada">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      
      <Label layoutX="31.0" layoutY="55.0" text="Partido:" />
      <ComboBox fx:id="cboPartido" layoutX="140.0" layoutY="51.0" prefWidth="200.0" promptText="Seleccione Partido" />
      
      <Label layoutX="31.0" layoutY="95.0" text="Número Asiento:" />
      <TextField fx:id="txtAsiento" layoutX="140.0" layoutY="91.0" prefWidth="200.0" promptText="Ej: A-12" />
      
      <Label layoutX="31.0" layoutY="135.0" text="Sección:" />
      <ComboBox fx:id="cboSeccion" layoutX="140.0" layoutY="131.0" prefWidth="200.0" promptText="Seleccione Sección" />
      
      <Label layoutX="31.0" layoutY="175.0" text="Precio (Q):" />
      <TextField fx:id="txtPrecio" layoutX="140.0" layoutY="171.0" prefWidth="200.0" promptText="Calculado por sección" />
      
      <Label layoutX="31.0" layoutY="215.0" text="Estado:" />
      <ComboBox fx:id="cboEstado" layoutX="140.0" layoutY="211.0" prefWidth="200.0" />
      
      <Button fx:id="btnGuardar" layoutX="31.0" layoutY="265.0" mnemonicParsing="false" onAction="#btnGuardarAction" prefHeight="30.0" prefWidth="100.0" text="Guardar" />
      <Button fx:id="btnModificar" layoutX="145.0" layoutY="265.0" mnemonicParsing="false" onAction="#btnModificarAction" prefHeight="30.0" prefWidth="100.0" text="Modificar" />
      <Button fx:id="btnEliminar" layoutX="260.0" layoutY="265.0" mnemonicParsing="false" onAction="#btnEliminarAction" prefHeight="30.0" prefWidth="100.0" text="Eliminar" />
      <Button fx:id="btnLimpiar" layoutX="375.0" layoutY="265.0" mnemonicParsing="false" onAction="#btnLimpiarAction" prefHeight="30.0" prefWidth="100.0" text="Limpiar" />
      
      <TableView fx:id="tablaTicket" layoutX="31.0" layoutY="315.0" prefHeight="240.0" prefWidth="760.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
          <TableColumn fx:id="colPartido" prefWidth="220.0" text="PARTIDO" />
          <TableColumn fx:id="colAsiento" prefWidth="100.0" text="ASIENTO" />
          <TableColumn fx:id="colSeccion" prefWidth="120.0" text="SECCIÓN" />
          <TableColumn fx:id="colPrecio" prefWidth="100.0" text="PRECIO" />
          <TableColumn fx:id="colEstado" prefWidth="140.0" text="ESTADO" />
        </columns>
      </TableView>

   </children>
</AnchorPane>