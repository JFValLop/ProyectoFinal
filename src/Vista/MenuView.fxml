<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ControladorFX.MenuFXController">
    <children>
        <HBox alignment="CENTER" prefHeight="56.0" spacing="20.0" style="-fx-background-color: #212121; -fx-padding: 15;">
            <children>
                <Label alignment="CENTER" prefWidth="140.0" text="MUNDIAL 2026" textFill="WHITE" HBox.hgrow="ALWAYS">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
               <HBox.margin>
                  <Insets right="500.0" top="15.0" />
               </HBox.margin>
               <padding>
                  <Insets bottom="15.0" right="10.0" />
               </padding>
                </Label>
                <Button mnemonicParsing="false" onAction="#cargarClientes" prefWidth="150.0" text="Clientes" />
                <Button mnemonicParsing="false" onAction="#cargarPartidos" prefWidth="150.0" text="Partidos" />
                <Button mnemonicParsing="false" onAction="#cargarTickets" prefWidth="150.0" text="Tickets">
               <HBox.margin>
                  <Insets right="50.0" />
               </HBox.margin>
            </Button>
            </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <VBox.margin>
            <Insets top="80.0" />
         </VBox.margin>
        </HBox>
      
              <AnchorPane fx:id="contenedorPrincipal" VBox.vgrow="ALWAYS" />
    </children>
</VBox>
